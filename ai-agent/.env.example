# Supabase (REST — чтение меню)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PostgreSQL (транзакции заказов)
# Supabase → Settings → Database → Connection string → URI (Transaction pooler)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# OpenAI Agents SDK
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# REST API для React (по умолчанию 3002)
AGENT_API_PORT=3002

# MCP HTTP (опционально, для hosted / удалённого агента)
MCP_HTTP_URL=http://localhost:3001/mcp
MCP_HTTP_PORT=3001
